      "strategicPurpose": "",
      "iconName": "Reverse_Time",
      "tips": "Powerful CC ability, use it on enemies with powerful mobility skills for highest effectiveness.",
      "iconUrl": "/raw-assets/skill_icons/diggie/reverse_time.png",
      "displayLabel": "Skill 2",
