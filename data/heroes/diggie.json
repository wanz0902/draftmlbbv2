      "comboUsage": "",
      "strategicPurpose": "",
      "iconName": "Auto_Alarm_Bomb",
      "tips": "When ticking down, tap again to detonate immediately. Early detonations will only slow instead of stunning. Best to let it tick for as long as possible, but don't be greedy for damage and let the enemy leave the explosion range.",
      "iconUrl": "/raw-assets/skill_icons/diggie/auto_alarm_bomb.png",
      "displayLabel": "Skill 1",
      "skillSlot": "skill1"
    },
    "skill2": {
      "name": "Reverse Time",
      "description": "Diggie marks the target enemy hero for 4s and pulls them back to their previous location after the duration ends, dealing 150( +100% Total Magic Power) (Magic Damage) and briefly slowing them by 80%. If the enemy moves out of the circle, the pull will be triggered early.",
      "cooldown": [
        10
