    "passive": {
      "name": "Assassin Instinct",
      "description": "If Natalia stays in a bush without taking damage for 1s, she will enter (Camouflage) state and gain 15% Movement Speed. In this state, Natalia's next Basic Attack will teleport her behind her target and deal 200( +110% Total Physical Attack) (Physical Damage) while silencing the target for 0.25s. Dealing damage, taking damage or using skills will immediately end the (Camouflage) state, but her next Basic Attack will remain enhanced for another 1s. Natalia's base Crit Damage is reduced to 150%, but her damage to Creeps is increased to 150%.",
      "cooldown": "0",
      "manaCost": "0",
      "damageType": "Physical",
      "scaling": [
        "(+110% Total Physical Attack)"
      ],
      "scalingTable": [],
