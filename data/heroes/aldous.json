    "skill1": {
      "name": "Contract: Soul Steal",
      "description": "Aldous unleashes his inner energy to enhance his next Basic Attack to deal (Physical Damage) equal to 200( +100% Total Physical Attack) plus 5 times the number of (Soul Steal) stacks. If this attack kills an enemy hero/Siege Minion/other non-hero unit, Aldous will gain 10/10/4 stacks of (Soul Steal) (up to 650 stacks). The enhanced Basic Attack deals 300% extra Base Damage to Minions or Creeps. Aldous gets an extra 5/2 stack(s) of (Soul Steal) when a nearby enemy Siege Minion/other non-hero unit dies.",
      "cooldown": [
        10
      ],
      "manaCost": [
        50
      ],
