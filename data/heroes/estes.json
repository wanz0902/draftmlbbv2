      "comboUsage": "",
      "strategicPurpose": "",
      "iconName": "Moonlight_Immersion",
      "tips": "Moonlight Immersion can immediately restore one of his ally's HP. When Estes is successfully links himself to his target ally, it will heal his ally with 200 HP for 3 seconds. But, being far from the target, the link chain will be broken and the healing will stop. This skill can also heal Estes himself if needed. Estes cannot restore one ally if his HP is very low also when he lacks of mana.",
      "iconUrl": "/raw-assets/skill_icons/estes/moonlight_immersion.png",
      "displayLabel": "Skill 1",
      "skillSlot": "skill1"
    },
    "skill2": {
      "name": "Domain of Moon Goddess",
      "description": "Estes drops a flood of moonlight on the target area, dealing 350( +70% Total Magic Power) (Magic Damage) to enemy units within it. Afterwards, it turns to a domain of the Moon Goddess and reveals enemies inside it. Enemies will be slowed by 90% for 1.5s if they touch the edge of the domain area. (The slow effect will decay over time.)",
      "cooldown": [
        10
      ],
      "manaCost": [
        50
      ],
      "damageType": "PHYSICAL",
      "scaling": [
        "None"
      ],
      "crowdControlType": [],
      "strategicTags": [],
      "comboUsage": "",
      "strategicPurpose": "",
      "iconName": "Domain_of_Moon_Goddess",
      "tips": "This skill is effectively use as a trap. Ring of trap that will slow down enemies and even monsters or creeps movements that also deals 350 magic damage to enemies within it. You can cast this right in front of you to slow enemies that attacks you. This can also be use to help your allies escape by making the enemies slow their movements. Whoever got into the ring cannot easily escape due to if they tried to run they will be slow if they touches the ring.",
      "iconUrl": "/raw-assets/skill_icons/estes/domain_of_moon_goddess.png",
      "displayLabel": "Skill 2",
      "skillSlot": "skill2"
    },
    "ultimate": {
      "name": "Blessing of Moon Goddess",
      "description": "Estes casts an enhanced (\"Moonlight Immersion\") on all nearby allied heroes. Within the next 8s, (\"Moonlight Immersion\") will be enhanced and Estes will continuously recover 1230( +210% Total Magic Power) HP.",
      "cooldown": [
        30
