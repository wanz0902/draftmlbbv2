# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for AI Draft Recommendation features
OPENAI_API_KEY="OPENAI_API_KEY"

# WAFER_API_KEY: Required for Wafer AI draft analysis (Qwen model)
WAFER_API_KEY="YOUR_WAFER_API_KEY"

# WAFER_MODEL: Legacy single-model config (kept for backward compat)
WAFER_MODEL="Qwen3.5-397B-A17B"

# Wafer AI 3-Tier Architecture
# Tier 1 (Realtime): Fast, cheap — ban/pick recommendations, coach panel
WAFER_REALTIME_MODEL="deepseek-v4-flash"
# Tier 2 (Analysis): Medium cost — post-draft analysis, matchup analysis
WAFER_ANALYSIS_MODEL="Qwen3.6-35B-A3B"
# Tier 3 (Premium): Expensive — deep analysis, export reports (never auto-called)
WAFER_PREMIUM_MODEL="Qwen3.5-397B-A17B"

# ─── TokenPlan/Mimo AI Provider (OpenAI-compatible) ───
# Base URL: Singapore endpoint for low-latency SEA access
TOKENPLAN_API_KEY="YOUR_TOKENPLAN_API_KEY"
TOKENPLAN_BASE_URL="https://token-plan-sgp.xiaomimimo.com/v1"
# Tier 1 (Realtime): Fast inference for coaching and recommendations
TOKENPLAN_REALTIME_MODEL="mimo-v2.5"
# Tier 2 (Analysis): Draft analysis and matchup evaluation
TOKENPLAN_ANALYSIS_MODEL="mimo-v2.5-pro"
# Tier 3 (Premium): Deep strategic analysis (never auto-called)
TOKENPLAN_PREMIUM_MODEL="mimo-v2.5-pro"

# ─── AI Provider Selection ───
# Primary provider used first; fallback kicks in on failure.
# Wafer is primary for PRODUCTION (MiMo/TokenPlan ToS is for coding tools, not production serving).
# Options: tokenplan, wafer
AI_PRIMARY_PROVIDER="wafer"
AI_FALLBACK_PROVIDER="tokenplan"

# AI environment: "production" routes user requests through Wafer.
# "development" skips AI narrative, uses local engine only (MiMo reserved for dev tooling).
AI_ENV="production"

# ─── Deep Analysis Gate ───
# /api/ai/deep-analysis uses expensive premium model.
# Keep disabled in production unless intentionally testing/admin use.
DEEP_ANALYSIS_ENABLED="false"
# Access token required for deep analysis when enabled (never expose to frontend).
DEEP_ANALYSIS_ACCESS_TOKEN="your_deep_analysis_access_token_here"

# ─── AI Diagnostics Gate ───
# Gates test/benchmark/cache-stats endpoints from public access.
# Keep disabled in production. Enable only for admin debugging.
AI_DIAGNOSTICS_ENABLED="false"
# Access token required for diagnostics when enabled (never expose publicly).
AI_DIAGNOSTICS_ACCESS_TOKEN="your_ai_diagnostics_access_token_here"

# ─── AI Rate Limiting ───
# In-memory rate limiter for user-facing AI endpoints (draft-analysis, recommendation-explain).
# Window in milliseconds. Default: 60000 (1 minute).
AI_RATE_LIMIT_WINDOW_MS="60000"
# Max draft analysis requests per client per window.
AI_DRAFT_ANALYSIS_LIMIT="10"
# Max recommendation explain requests per client per window.
AI_RECOMMENDATION_EXPLAIN_LIMIT="30"
# Max legacy /api/draft/ai-recommend requests per client per window.
AI_LEGACY_RECOMMEND_LIMIT="20"
# Max legacy /api/draft/final-analysis requests per client per window.
AI_LEGACY_FINAL_ANALYSIS_LIMIT="10"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
