{
  "name": "mlbb-draft-simulator",
  "version": "1.0.0",
  "description": "Mobile Legends professional draft pick simulator and Liquipedia stats dashboard.",
  "main": "dist/server.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "validate:data": "tsx scripts/validate-data.ts",
    "validate:assets": "tsx scripts/validate-assets.ts",
    "sync:global-rank": "tsx scripts/sync-global-rank.ts"
  },
  "keywords": [
    "mlbb",
    "draft",
    "simulator",
    "liquipedia",
    "stats"
  ],
  "author": "AI Studio Build",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.3.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.41.0",
    "p-queue": "^9.3.0",
    "playwright": "^1.60.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
